generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// NextAuth models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  bio           String?
  locale        String    @default("ja")
  emailNotifications Boolean @default(true)
  // Granular notification preferences (master switch: emailNotifications)
  notifyAuditComplete Boolean @default(true)
  notifyAlerts        Boolean @default(true)
  notifyQuarterly     Boolean @default(true)
  notifyFollowUp      Boolean @default(true)
  notifyMarketing     Boolean @default(true)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ──────────────────────────────────────────────
// Business models
// ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  website   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Onboarding & scheduling
  onboardingComplete Boolean @default(false)
  auditWeek          Int?    // 3 or 4 (3rd or 4th week of month)
  auditDayOfWeek     Int?    // 1=Mon..5=Fri
  welcomeAuditSent   Boolean @default(false)

  // Repo change policy
  repoChangesUsed    Int     @default(0)   // lifetime changes consumed
  repoChangesAllowed Int     @default(3)   // admin-adjustable cap

  users               User[]
  subscription        Subscription?
  repos               Repo[]
  audits              Audit[]
  messages            Message[]
  contactRequest      ContactRequest[]
  freeEvalReports     FreeEvalReport[]
  notifications       NotificationLog[]
  repoChangeLogs      RepoChangeLog[]
  monitorChecks       MonitorCheck[]
  alerts              Alert[]
  satisfactionRatings SatisfactionRating[]
  addOns              AddOn[]
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String       @unique
  plan           Plan
  billingCycle   BillingCycle @default(MONTHLY)
  status         SubStatus    @default(ACTIVE)

  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  // Grace period for failed payments
  gracePeriodEnd DateTime?
  pausedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     Payment[]
}

model Payment {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Int
  currency       String   @default("jpy")
  status         String
  stripeInvoiceId String? @unique
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model Repo {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  url            String
  stack          Stack    @default(OTHER)
  isRepoless     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audits        Audit[]
  monitorChecks MonitorCheck[]
  alerts        Alert[]
}

model Audit {
  id             String      @id @default(cuid())
  organizationId String
  repoId         String
  status         AuditStatus @default(SCHEDULED)

  reportCode     String?   @unique   // WM-YYYYMM-XXX
  reportPdfUrl   String?
  findingsPdfUrl String?
  reportMdKey    String?             // R2 key for report-ja.md source
  prLinks        String[]

  // Audit type and depth
  isWelcome     Boolean  @default(false)
  auditDepth    String?  // "lite" or "full"
  retryCount    Int      @default(0)
  failedAt      DateTime?
  failureReason String?

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repo         Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  findings     Finding[]

  @@index([organizationId, createdAt])
  @@index([repoId, createdAt])
}

model Finding {
  id       String   @id @default(cuid())
  auditId  String
  title    String
  severity Severity
  evidence String
  impact   String
  fix      String
  effort   Effort
  safeAutoFix Boolean @default(false)
  prUrl    String?
  createdAt DateTime @default(now())

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model Message {
  id               String   @id @default(cuid())
  organizationId   String
  fromOperator     Boolean  @default(false)
  content          String
  readByOperator   Boolean  @default(false)
  readByClient     Boolean  @default(false)
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ContactRequest {
  id             String      @id @default(cuid())
  name           String
  email          String
  url            String?
  stack          String?
  message        String?
  status         EvalStatus  @default(PENDING)
  notes          String?
  organizationId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([status])
}

model FreeEvalReport {
  id             String   @id @default(cuid())
  organizationId String
  siteUrl        String?
  pdfKey         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  type           String   // onboarding_24h, onboarding_72h, onboarding_7d, audit_scheduled, audit_complete, pr_fixes, monthly_digest, drip_1, drip_2, drip_3
  sentAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
}

model StripeEvent {
  id        String   @id  // Stripe event ID (evt_xxx)
  createdAt DateTime @default(now())
}

model RepoChangeLog {
  id             String   @id @default(cuid())
  organizationId String
  repoId         String?
  action         String   // "ADD" | "REMOVE" | "REPLACE"
  isInitialSetup Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ──────────────────────────────────────────────
// Monitoring models
// ──────────────────────────────────────────────

model MonitorCheck {
  id             String   @id @default(cuid())
  organizationId String
  repoId         String
  checkType      String   // "uptime" | "ssl_expiry" | "security_headers" | "performance"
  status         String   // "OK" | "WARNING" | "CRITICAL"
  value          String?  // e.g. "HTTP 200 (320ms)", "Expires in 45 days", "Missing: HSTS"
  responseTimeMs Int?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repo         Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([repoId, checkType, createdAt])
}

model Alert {
  id             String    @id @default(cuid())
  organizationId String
  repoId         String
  checkType      String    // "uptime" | "ssl_expiry" | "security_headers" | "performance"
  severity       String    // "WARNING" | "CRITICAL"
  message        String
  resolvedAt     DateTime?
  notifiedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repo         Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([organizationId, resolvedAt])
  @@index([repoId, checkType])
}

model SatisfactionRating {
  id             String   @id @default(cuid())
  organizationId String
  auditId        String?
  score          Int      // 1–5
  comment        String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AddOn {
  id               String      @id @default(cuid())
  organizationId   String
  auditId          String?
  findingId        String?
  type             AddOnType   @default(FIX_IT)
  status           AddOnStatus @default(PENDING)
  effort           Effort?
  amount           Int         // in JPY
  stripeSessionId  String?     @unique
  stripePaymentIntentId String?
  notes            String?     // operator notes
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeSessionId])
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum Stack {
  SHOPIFY
  WORDPRESS
  NEXTJS
  LINE_MINI_APP
  OTHER
}

enum AuditStatus {
  SCHEDULED
  IN_PROGRESS
  REVIEW
  DELIVERED
  COMPLETED
  FAILED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Effort {
  QUICK_WIN
  MODERATE
  LARGE
}

enum EvalStatus {
  PENDING
  REVIEWING
  COMPLETED
  REJECTED
}

enum AddOnType {
  FIX_IT
  CONSULTATION
}

enum AddOnStatus {
  PENDING
  PAID
  IN_PROGRESS
  COMPLETED
  REFUNDED
}
