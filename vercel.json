{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/check-audits",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/check-notifications",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/check-monitors",
      "schedule": "0 21 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/stripe/webhook",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
